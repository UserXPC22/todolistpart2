<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todolistpart2.Views.Tasks.TaskDetailsPage"
             Title="Task Details">

    <VerticalStackLayout Spacing="20" Padding="30">
        
        <Label Text="Edit Task" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

        <Entry x:Name="EditNameEntry" Placeholder="Task Name" />
        
        <Editor x:Name="EditDescriptionEntry" Placeholder="Description" HeightRequest="150" />

        <Button Text="Update Task" 
                BackgroundColor="#9b9cd7" 
                TextColor="White" 
                Clicked="OnUpdateClicked" />

        <Button x:Name="StatusActionButton"
                Text="Complete Task" 
                BackgroundColor="Green" 
                TextColor="White" 
                Clicked="OnStatusActionClicked" />

        <Button Text="Delete Task" 
                BackgroundColor="Transparent" 
                TextColor="Red" 
                Clicked="OnDeleteClicked" />

    </VerticalStackLayout>
</ContentPage>