<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todolistpart2.Views.Tasks.CompletedPage"
             Title="Completed Tasks">

    <ListView x:Name="CompletedListView" 
              Margin="20" 
              ItemSelected="OnItemSelected"
              HasUnevenRows="True">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <Grid Padding="10" ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="{Binding item_name}" 
                                   TextColor="Gray" 
                                   FontAttributes="Italic"
                                   FontSize="18"/>
                            <Label Text="Status: Done" 
                                   FontSize="12" 
                                   TextColor="Green"/>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <Button Text="↩" 
                                    BackgroundColor="Orange" 
                                    TextColor="White" 
                                    WidthRequest="45" 
                                    HeightRequest="45" 
                                    CornerRadius="22"
                                    Clicked="OnRestoreButtonClicked" 
                                    CommandParameter="{Binding .}"/>
                            <Button Text="🗑" 
                                    BackgroundColor="Red" 
                                    TextColor="White" 
                                    WidthRequest="45" 
                                    HeightRequest="45" 
                                    CornerRadius="22"
                                    Clicked="OnDeleteButtonClicked" 
                                    CommandParameter="{Binding .}"/>
                        </HorizontalStackLayout>
                    </Grid>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentPage>
