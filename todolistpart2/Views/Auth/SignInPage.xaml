<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todolistpart2.Views.Auth.SignInPage"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="30" VerticalOptions="Center">
            

            <Label Text="Welcome back"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2C2C2A"
                   Margin="0,0,0,6"/>

            <Label Text="Sign in to your account"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#888780"
                   Margin="4,0,0,32"/>

            <Label Text="Email"
                   FontSize="13"
                   TextColor="#888780"
                   Margin="0,0,0,6"/>

            
                   <Entry x:Name="EmailEntry"
                          Placeholder="you@example.com"
                          Keyboard="Email"
                          BackgroundColor="Transparent"
                          FontSize="15"
                          Margin="0,0,0,20"/>
           

            <Label Text="Password"
                   FontSize="13"
                   TextColor="#888780"
                   Margin="0,8,0,6"/>
            
                <Entry x:Name="PasswordEntry"
                       Placeholder="••••••••"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       FontSize="15"
                       Margin="0,0,0,40"/>

            <Button Text="Sign in"
                    BackgroundColor="#7F77DD"
                    TextColor="White"
                    CornerRadius="8"
                    FontSize="15"
                    HeightRequest="50"
                    Clicked="OnSignInClicked"
                    Margin="0,0,0,20"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,20">
                <Label Text="Don't have an account?"
                       FontSize="14"
                       TextColor="#888780"
                       VerticalOptions="Center"/>
                <Label Text="Sign up"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#7F77DD"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignUpClicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>