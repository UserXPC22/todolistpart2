<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todolistpart2.SignUpPage"
             Title="Sign Up">

    <VerticalStackLayout Spacing="15" Padding="30" VerticalOptions="Center">
        
        <Image Source="dotnet_bot.png" HeightRequest="120" HorizontalOptions="Center" />

        <Entry Placeholder="User name" />

        <Entry Placeholder="Email address" 
               Keyboard="Email" />

        <Entry Placeholder="Password" 
               IsPassword="True" />

        <Entry Placeholder="Confirm Password" 
               IsPassword="True" />

        <Button Text="Sign up" 
                BackgroundColor="#9b9cd7" 
                TextColor="White" />

        <Button Text="Sign In" 
                BackgroundColor="Transparent" 
                TextColor="#9b9cd7" 
                Clicked="OnSignInClicked"/>

    </VerticalStackLayout>
</ContentPage>