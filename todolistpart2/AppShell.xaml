<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="todolistpart2.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:todolistpart2"
    xmlns:tasks="clr-namespace:todolistpart2.Views.Tasks"
    xmlns:main="clr-namespace:todolistpart2.Views.Main"
    xmlns:auth="clr-namespace:todolistpart2.Views.Auth"
    Title="todolistpart2">

    <TabBar>
    <ShellContent
        Title="ToDo"
        Icon="dotnet_bot.png"
        ContentTemplate="{DataTemplate tasks:ToDoPage}" />

    <ShellContent
        Title="Completed"
        Icon="dotnet_bot.png"
        ContentTemplate="{DataTemplate tasks:CompletedPage}" />

    <ShellContent
        Title="Profile"
        Icon="dotnet_bot.png"
        ContentTemplate="{DataTemplate main:ProfilePage}" />
</TabBar>

</Shell>