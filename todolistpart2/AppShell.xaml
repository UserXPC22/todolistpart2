<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="todolistpart2.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:todolistpart2"
    Title="todolistpart2">

    <TabBar>
        <Tab Title="ToDo" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:ToDoPage}" />
        </Tab>

        <Tab Title="Completed" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:CompletedPage}" />
        </Tab>

        <Tab Title="Profile" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:ProfilePage}" />
        </Tab>
    </TabBar>

</Shell>