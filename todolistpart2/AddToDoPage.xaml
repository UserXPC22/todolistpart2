<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todolistpart2.AddToDoPage"
             Title="Add New Task">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Start">
        
        <Label Text="Create a New Task" 
               FontSize="24" 
               HorizontalOptions="Center" 
               TextColor="#9b9cd7" 
               FontAttributes="Bold" />

        <Entry x:Name="TaskNameEntry" 
               Placeholder="Task Name" />

        <Editor x:Name="DescriptionEntry" 
                Placeholder="Task Description" 
                HeightRequest="100" />

        <Button Text="Save Task" 
                BackgroundColor="#9b9cd7" 
                TextColor="White" 
                Clicked="OnSaveClicked" />

    </VerticalStackLayout>
</ContentPage>